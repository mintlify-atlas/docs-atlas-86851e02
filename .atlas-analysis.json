  "keyFeatures": [
    "OAuth 2.0 PKCE authentication for secure API access",
    "Complete CRUD operations for members, plans, and data tables",
    "CSV and JSON import/export for bulk data operations",
    "Environment mode switching (sandbox/live)",
    "Formatted table output or raw JSON for scripting",
    "AI agent skills for Claude Code and Codex integration",
    "GraphQL-powered API with automatic token refresh",
    "Permission and price management for membership plans"
  ],
  "publicApiSurface": [
    "memberstack auth login",
    "memberstack auth logout",
    "memberstack auth status",
